/target
**/*.rs.bk
.idea/
.vscode/
.DS_Store
*.swp
# IronLint runtime state (telemetry log, session state, baseline cache)
.ironlint/
# Local Claude Code agent state (worktrees, settings).
.claude/
# Superpowers scratch workspace (SDD artifacts, task reports, ephemeral plans).
.superpowers/
# Machine-local coding-agent install state and tool caches — created by
# `ironlint init` (adapter wiring) or local tools, never repo content.
.pi/
.opencode/
.agents/
.codegraph/
.understand-anything/
# cargo-mutants local report directories (current run + previous run rename).
mutants.out*/
# `cargo mutants --in-diff pr.diff` scratch — diff file generated on demand.
pr.diff
# LLVM coverage instrumentation that occasionally leaks outside target/.
*.profraw
# Per-case run forensics for the adapter Docker e2e harness — overwritten each run.
tests/e2e/*/runs/
# API key file for the Docker e2e harness (template `.env.e2e.example` is committed).
tests/e2e/.env.e2e

# repowise API keys (local)
.repowise/.env

# Ignore any .env file (secrets) — matches .env at any depth.
.env
# Local repowise tool cache/state (multi-MB wiki.db, lancedb, run state) and
# the machine-local MCP config that drives it — not part of ironlint.
/.repowise/
.mcp.json
# Node.js dependencies (adapters)
node_modules/
